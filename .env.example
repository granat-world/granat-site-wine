# Copy to .env locally. NEVER commit .env to git.
# In Timeweb App Platform, set these in step 5 "Переменные".

# Cone Red voice processing API
GRANAT_API_BASE=https://granat-api.apps.cone.red
GRANAT_API_KEY=replace-me-with-real-key

# Most APIs use X-API-Key. If Cone Red docs say "Authorization: Bearer", change to:
#   API_KEY_HEADER=Authorization
# (and prefix the key with "Bearer " in GRANAT_API_KEY)
API_KEY_HEADER=X-API-Key

# Server
PORT=3000
MAX_UPLOAD_MB=50
